# Database settings
POSTGRES_HOST=db
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_postgres_db_name

# Application settings
# Токен доступа для API hh.ru
ACCESS_TOKEN_HH=your_hh_access_token
# Мастер-ключ для создания и деактивации других API-ключей
MASTER_API_KEY=your_super_secret_master_key
# Секрет для сессий административной панели (любая случайная строка, мин. 32 символа)
SECRET_KEY=your_secret_key_for_admin_sessions
# Учётные данные для входа в /admin
ADMIN_LOGIN=admin
ADMIN_PASSWORD=your_admin_password

LOGGING_CONFIG_PATH=logging.ini

# LLM settings (для AI-ассистента «Вера»)
LLM_API_KEY=your_llm_api_key
LLM_API_URL=https://your-llm-provider.example.com/v1
LLM_MODEL=your_model_name
